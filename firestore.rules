rules_version = '2';

// Servio admin portal — Firestore Security Rules.
//
// These rules are the AUTHORITATIVE access control for the admin data. The
// client-side guards in src/admin (route guards, `can()` checks) are UX only
// and can be bypassed; THESE rules are what actually protect the data on the
// server. The role -> capability matrix below mirrors
// src/admin/rbac/permissions.ts — keep the two in sync.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers -------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function adminPath() {
      return /databases/$(database)/documents/admins/$(request.auth.uid);
    }

    function adminData() {
      return get(adminPath()).data;
    }

    // A valid, enabled admin account.
    function isAdmin() {
      return isSignedIn()
        && exists(adminPath())
        && adminData().disabled != true;
    }

    function role() {
      return adminData().role;
    }

    function isSuperAdmin() {
      return isAdmin() && role() == 'super_admin';
    }

    // Capability check mirroring the role -> permission matrix.
    function can(perm) {
      return isAdmin() && (
        role() == 'super_admin'
        || (role() == 'frontend_dev' && perm in [
              'dashboard:view', 'projects:view', 'projects:edit',
              'clients:view', 'messages:view', 'messages:reply'
            ])
        || (role() == 'backend_dev' && perm in [
              'dashboard:view', 'projects:view', 'projects:edit', 'projects:assign',
              'clients:view', 'clients:edit', 'messages:view', 'messages:reply',
              'audit:view'
            ])
        || (role() == 'qa_delivery' && perm in [
              'dashboard:view', 'projects:view', 'clients:view',
              'messages:view', 'messages:reply'
            ])
      );
    }

    // ---- admins --------------------------------------------------------

    match /admins/{uid} {
      // Read your own profile; super admins can read everyone.
      allow get: if isSignedIn() && (request.auth.uid == uid || isSuperAdmin());
      allow list: if isSuperAdmin();

      // Creating/removing admin accounts is super-admin only.
      allow create, delete: if isSuperAdmin();

      // Updates: super admins may change anything (role, disabled, ...).
      // The account owner may only touch their own profile/PIN fields — the
      // key allowlist makes it impossible to change role/disabled (or inject
      // any unexpected field), so no self-escalation is possible.
      allow update: if isSuperAdmin()
        || (
          request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
               'displayName', 'email',
               'pinHash', 'pinSalt', 'pinIterations',
               'updatedAt', 'lastLoginAt'
             ])
        );
    }

    // ---- projects ------------------------------------------------------

    match /projects/{id} {
      allow read:           if can('projects:view');
      allow create, update: if can('projects:edit');
      allow delete:         if can('projects:delete');
    }

    // ---- project updates (admin -> client feed) ------------------------

    // Updates an admin posts for a client's project, shown on the client
    // dashboard's Updates section. Addressed by the client's email (the only
    // identifier shared between what an admin knows and the client's auth
    // token), stored lowercased so the read comparison is case-insensitive.
    match /projectUpdates/{id} {
      // A signed-in client may read ONLY the updates addressed to their own
      // email — and only once that email is VERIFIED, since addressing is by
      // email and Firebase lets anyone register an arbitrary (unverified)
      // address. Without this check an attacker could pre-register an unclaimed
      // client's email and read their feed. The client app sends a verification
      // mail on sign-up and gates the Updates UI on `emailVerified`; Google
      // sign-in is verified automatically. Any admin who can view projects may
      // read all. The match is case-insensitive (lowercased on both sides).
      allow read: if can('projects:view')
        || (
          isSignedIn()
          && request.auth.token.email != null
          && request.auth.token.email_verified == true
          && resource.data.clientEmail == request.auth.token.email.lower()
        );

      // Only admins who can edit projects may post. The shape is pinned hard so
      // the collection can never be abused as arbitrary client-writable storage:
      // exact key set, bounded sizes, a known `type`, an email that is already
      // lowercased (so reads match), and a server-stamped timestamp.
      allow create: if can('projects:edit')
        && request.resource.data.keys().hasOnly(
             ['clientEmail', 'title', 'description', 'type', 'createdAt'])
        && request.resource.data.keys().hasAll(
             ['clientEmail', 'title', 'description', 'type', 'createdAt'])
        && request.resource.data.clientEmail is string
        && request.resource.data.clientEmail.size() > 0
        && request.resource.data.clientEmail.size() < 320
        && request.resource.data.clientEmail == request.resource.data.clientEmail.lower()
        && request.resource.data.clientEmail.matches('^[^[:space:]@]+@[^[:space:]@]+[.][^[:space:]@]+$')
        && request.resource.data.title is string
        && request.resource.data.title.matches('.*\\S.*')
        && request.resource.data.title.size() < 200
        && request.resource.data.description is string
        && request.resource.data.description.matches('.*\\S.*')
        && request.resource.data.description.size() < 5000
        && request.resource.data.type in ['feature', 'bugfix', 'milestone', 'info']
        && request.resource.data.createdAt == request.time;

      // Updates are immutable once posted; an editing admin may remove them.
      allow update: if false;
      allow delete: if can('projects:edit');
    }

    // ---- project billing (admin -> client payments) --------------------

    // A client's project billing — total cost + the list of recorded payments —
    // shown on the client dashboard's Payments section. One document per client,
    // addressed by (and keyed on) the client's lowercased email, the only
    // identifier shared between what an admin knows and the client's auth token.
    // The amount-paid / remaining figures are DERIVED on the client from the
    // payments, never stored.
    match /projectBilling/{id} {
      // A signed-in client may read ONLY their own billing — and only once their
      // email is VERIFIED. Addressing is by email and Firebase lets anyone
      // register an arbitrary (unverified) address, so without this an attacker
      // could pre-register an unclaimed client's email and read their billing.
      // The client app gates the Payments UI on `emailVerified`; Google sign-in
      // is verified automatically. Any admin who can view projects may read all.
      allow read: if can('projects:view')
        || (
          isSignedIn()
          && request.auth.token.email != null
          && request.auth.token.email_verified == true
          && resource.data.clientEmail == request.auth.token.email.lower()
        );

      // Only admins who can edit projects may author billing. The top-level shape
      // is pinned hard (exact key set, bounded total cost, an already-lowercased
      // email, server-stamped timestamps). NOTE: Firestore rules cannot iterate a
      // list, so individual `payments` entries are validated by the client parser
      // (`src/dashboard/lib/payments.ts`), not here — acceptable because writes
      // are restricted to trusted projects:edit admins. The list size is bounded
      // to keep the document well under Firestore's 1 MiB limit.
      allow create: if can('projects:edit')
        && request.resource.data.keys().hasOnly(
             ['clientEmail', 'totalCost', 'payments', 'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasAll(
             ['clientEmail', 'totalCost', 'payments', 'createdAt', 'updatedAt'])
        && request.resource.data.clientEmail is string
        && request.resource.data.clientEmail.size() > 0
        && request.resource.data.clientEmail.size() < 320
        && request.resource.data.clientEmail == request.resource.data.clientEmail.lower()
        && request.resource.data.clientEmail.matches('^[^[:space:]@]+@[^[:space:]@]+[.][^[:space:]@]+$')
        && request.resource.data.totalCost is number
        && request.resource.data.totalCost >= 0
        && request.resource.data.totalCost < 1000000000000
        && request.resource.data.payments is list
        && request.resource.data.payments.size() < 500
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      // An editing admin may update only the mutable fields; the addressee email
      // and creation time are immutable (kept out of the affected-keys allowlist),
      // and updatedAt is re-stamped to the server clock.
      allow update: if can('projects:edit')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['totalCost', 'payments', 'updatedAt'])
        && request.resource.data.totalCost is number
        && request.resource.data.totalCost >= 0
        && request.resource.data.totalCost < 1000000000000
        && request.resource.data.payments is list
        && request.resource.data.payments.size() < 500
        && request.resource.data.updatedAt == request.time;

      allow delete: if can('projects:edit');
    }

    // ---- project invoices (admin -> client invoices) -------------------

    // Invoices an admin issues to a client, shown on the client dashboard's
    // Invoices section. Addressed by the client's lowercased email (the only
    // identifier shared between admin and client). A client may read ONLY their
    // own invoices, and only once their email is VERIFIED (the same pre-claimed
    // -address risk as the other email-addressed collections). projects:view
    // admins read all. projects:edit admins issue/edit/delete with the shape
    // pinned and timestamps server-stamped; the total is derived by the client
    // from the items, so only the items are stored.
    match /projectInvoices/{id} {
      function validInvoiceData(data) {
        return data.clientEmail is string
          && data.clientEmail.size() > 0
          && data.clientEmail.size() < 320
          && data.clientEmail == data.clientEmail.lower()
          && data.clientEmail.matches('^[^[:space:]@]+@[^[:space:]@]+[.][^[:space:]@]+$')
          && data.number is string
          && data.number.matches('.*\\S.*')
          && data.number.size() < 100
          && data.date is string
          && data.date.size() < 40
          && data.dueDate is string
          && data.dueDate.size() < 40
          && data.status in ['paid', 'unpaid', 'overdue']
          && data.items is list
          && data.items.size() < 100;
      }

      allow read: if can('projects:view')
        || (
          isSignedIn()
          && request.auth.token.email != null
          && request.auth.token.email_verified == true
          && resource.data.clientEmail == request.auth.token.email.lower()
        );

      allow create: if can('projects:edit')
        && request.resource.data.keys().hasOnly(
             ['clientEmail', 'number', 'date', 'dueDate', 'status', 'items',
              'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasAll(
             ['clientEmail', 'number', 'date', 'dueDate', 'status', 'items',
              'createdAt', 'updatedAt'])
        && validInvoiceData(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      // Editable (e.g. mark paid); clientEmail and createdAt are immutable.
      allow update: if can('projects:edit')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['number', 'date', 'dueDate', 'status', 'items', 'updatedAt'])
        && validInvoiceData(request.resource.data)
        && request.resource.data.updatedAt == request.time;

      allow delete: if can('projects:edit');
    }

    // ---- portfolio (admin-managed public showcase) ---------------------

    // Showcase projects managed from the admin dashboard and rendered on the
    // public marketing site. The PUBLIC (unauthenticated) visitor may read only
    // PUBLISHED items; admins who can view projects read everything incl. drafts.
    // Writes are restricted to projects:edit admins with the document shape
    // pinned and timestamps server-stamped, so the collection can never be abused
    // as arbitrary publicly-readable storage. createdAt is immutable on update.
    match /portfolio/{id} {
      function validPortfolioData(data) {
        return data.title is string
          && data.title.matches('.*\\S.*')
          && data.title.size() < 200
          && data.description is string
          && data.description.size() < 5000
          && data.category in ['Business', 'E-Commerce', 'SaaS', 'Other']
          && data.industry is string
          && data.industry.size() < 200
          && data.imageUrl is string
          && data.imageUrl.size() < 2000
          && data.technologies is list
          && data.technologies.size() < 50
          && data.projectUrl is string
          && data.projectUrl.size() < 2000
          && data.githubUrl is string
          && data.githubUrl.size() < 2000
          && data.order is number
          && data.published is bool;
      }

      allow read: if resource.data.published == true || can('projects:view');

      allow create: if can('projects:edit')
        && request.resource.data.keys().hasOnly(
             ['title', 'description', 'category', 'industry', 'imageUrl',
              'technologies', 'projectUrl', 'githubUrl', 'order', 'published',
              'createdAt', 'updatedAt'])
        && request.resource.data.keys().hasAll(
             ['title', 'description', 'category', 'industry', 'imageUrl',
              'technologies', 'projectUrl', 'githubUrl', 'order', 'published',
              'createdAt', 'updatedAt'])
        && validPortfolioData(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if can('projects:edit')
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['title', 'description', 'category', 'industry', 'imageUrl',
              'technologies', 'projectUrl', 'githubUrl', 'order', 'published',
              'updatedAt'])
        && validPortfolioData(request.resource.data)
        && request.resource.data.updatedAt == request.time;

      allow delete: if can('projects:edit');
    }

    // ---- clients -------------------------------------------------------

    match /clients/{id} {
      allow read:           if can('clients:view');
      allow create, update: if can('clients:edit');
      allow delete:         if isSuperAdmin();
    }

    // ---- messages ------------------------------------------------------

    match /messages/{id} {
      // The public website may submit a contact/quote message. Lock the shape
      // down hard: required server timestamp (blocks inbox-ordering tricks),
      // bounded string sizes (blocks oversized/DoS writes), basic email shape,
      // and status pinned to 'new'. For scripted-spam protection beyond rules,
      // enable Firebase App Check and/or a rate-limited callable function.
      allow create: if
        request.resource.data.keys().hasOnly(
          ['name', 'email', 'subject', 'body', 'status', 'createdAt']
        )
        && request.resource.data.keys().hasAll(
          ['name', 'email', 'body', 'status', 'createdAt']
        )
        && request.resource.data.status == 'new'
        && request.resource.data.createdAt == request.time
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() < 250
        && request.resource.data.email is string
        && request.resource.data.email.size() < 320
        && request.resource.data.email.matches('^[^@]+@[^@]+[.][^@]+$')
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() < 5000
        && (
          !('subject' in request.resource.data)
          || (request.resource.data.subject is string
              && request.resource.data.subject.size() < 300)
        );

      allow read:   if can('messages:view');
      allow update: if can('messages:reply');
      allow delete: if isSuperAdmin();
    }

    // ---- mail (outbound email queue) -----------------------------------

    // Consumed by the Firebase "Trigger Email" extension, which sends each new
    // document as an email. The public quote form writes here to notify the
    // business of a new lead. Locked down hard so it can never be used as an
    // open relay: the recipient is pinned to a single owner address (keep in
    // sync with QUOTE_NOTIFY_EMAIL in src/app/lib/submitQuote.ts), only the
    // message body is caller-controlled, and every size is bounded. As with
    // `messages`, enable Firebase App Check for scripted-spam protection. The
    // extension runs with Admin privileges, so it bypasses these rules to stamp
    // its own `delivery` status and read the queue.
    match /mail/{id} {
      allow create: if
        request.resource.data.keys().hasOnly(
          ['to', 'replyTo', 'message', 'createdAt']
        )
        && request.resource.data.keys().hasAll(['to', 'message', 'createdAt'])
        && request.resource.data.to == ['hello@servio.dev']
        && request.resource.data.createdAt == request.time
        && (
          !('replyTo' in request.resource.data)
          || (request.resource.data.replyTo is string
              && request.resource.data.replyTo.size() < 320
              && request.resource.data.replyTo.matches('^[^[:space:]@]+@[^[:space:]@]+[.][^[:space:]@]+$'))
        )
        && request.resource.data.message is map
        && request.resource.data.message.keys().hasOnly(['subject', 'text', 'html'])
        && request.resource.data.message.keys().hasAll(['subject', 'text'])
        && request.resource.data.message.subject is string
        && request.resource.data.message.subject.size() > 0
        && request.resource.data.message.subject.size() < 300
        && request.resource.data.message.text is string
        && request.resource.data.message.text.size() > 0
        && request.resource.data.message.text.size() < 10000
        && (
          !('html' in request.resource.data.message)
          || (request.resource.data.message.html is string
              && request.resource.data.message.html.size() < 20000)
        );

      // Only the Trigger Email extension (Admin SDK) touches the queue.
      allow read, update, delete: if false;
    }

    // ---- audit_logs ----------------------------------------------------

    match /audit_logs/{id} {
      allow read: if can('audit:view');

      // Append-only and unforgeable: an admin may write log entries only for
      // themselves, with the actor email bound to their auth token and the
      // timestamp bound to the server clock (no spoofing / backdating).
      // Entries can never be edited or deleted.
      allow create: if isAdmin()
        && request.resource.data.keys().hasOnly([
             'actorUid', 'actorEmail', 'action',
             'targetType', 'targetId', 'metadata', 'createdAt'
           ])
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorEmail == request.auth.token.email
        && request.resource.data.createdAt == request.time
        && request.resource.data.action is string
        && request.resource.data.action.size() > 0
        && request.resource.data.action.size() < 200;
      allow update, delete: if false;
    }

    // ---- estimations (AI project-estimation history) -------------------

    // Per-user history of AI cost estimates produced by the dashboard's
    // estimator. Each document is owned by the signed-in user who created it
    // (addressed by their auth uid). A user may create and read ONLY their own
    // estimates; records are immutable history (no update/delete). Without this
    // rule the estimator's save was denied by default, surfacing "Missing or
    // insufficient permissions" and hiding the computed estimate (issue #184).
    match /estimations/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(
             ['userId', 'description', 'result', 'createdAt'])
        && request.resource.data.keys().hasAll(
             ['userId', 'description', 'result', 'createdAt'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() < 5001
        && request.resource.data.createdAt is string
        // Pin the result to the fixed EstimationResult shape so the collection
        // can't be abused as arbitrary client-writable storage (rules can't
        // iterate the features list, so it's only length-bounded — mirroring
        // projectBilling.payments).
        && request.resource.data.result is map
        && request.resource.data.result.keys().hasOnly(
             ['projectType', 'overallComplexity', 'features',
              'estimatedCostMin', 'estimatedCostMax',
              'estimatedTimeline', 'explanation'])
        && request.resource.data.result.keys().hasAll(
             ['projectType', 'overallComplexity', 'features',
              'estimatedCostMin', 'estimatedCostMax',
              'estimatedTimeline', 'explanation'])
        && request.resource.data.result.overallComplexity in
             ['low', 'medium', 'high', 'enterprise']
        && request.resource.data.result.estimatedCostMin is number
        && request.resource.data.result.estimatedCostMax is number
        && request.resource.data.result.features is list
        && request.resource.data.result.features.size() < 100
        && request.resource.data.result.projectType is string
        && request.resource.data.result.projectType.size() < 200
        && request.resource.data.result.estimatedTimeline is string
        && request.resource.data.result.estimatedTimeline.size() < 100
        && request.resource.data.result.explanation is string
        && request.resource.data.result.explanation.size() < 4000;

      allow update, delete: if false;
    }

    // Everything else is denied by default.
  }
}
